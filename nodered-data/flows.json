    {
        "id": "func_mieszkanie",
        "type": "function",
        "z": "92e6400d7068ca5b",
        "name": "Symulacja Mieszkanie",
        "func": "const hour = new Date().getHours();\nlet base = 0.1;\nif (hour >= 6 && hour < 9) base = 1.8;\nelse if (hour >= 9 && hour < 17) base = 0.4;\nelse if (hour >= 17 && hour < 23) base = 2.2;\nelse base = 0.1;\nconst power = +(base + (Math.random() * 0.4 - 0.2)).toFixed(2);\nmsg.payload = JSON.stringify({ power: power, location: 'mieszkanie' });\nmsg.topic = 'home/energy/mieszkanie';\nreturn msg;",
        "outputs": 1,
        "x": 160,
        "y": 220,
        "wires": [
            [
                "mqtt_out"
            ]
        ]
    },
