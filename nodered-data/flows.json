    {
        "id": "func_biuro",
        "type": "function",
        "z": "92e6400d7068ca5b",
        "name": "Symulacja Biuro",
        "func": "const hour = new Date().getHours();\nconst day = new Date().getDay();\nlet base = 0.05;\nif (day >= 1 && day <= 5) {\n  if (hour >= 8 && hour < 17) base = 3.5;\n  else if (hour >= 7 && hour < 8) base = 1.0;\n  else if (hour >= 17 && hour < 18) base = 1.0;\n}\nconst power = +(base + (Math.random() * 0.5 - 0.25)).toFixed(2);\nmsg.payload = JSON.stringify({ power: Math.max(0, power), location: 'biuro' });\nmsg.topic = 'home/energy/biuro';\nreturn msg;",
        "outputs": 1,
        "x": 1140,
        "y": 300,
        "wires": [
            [
                "mqtt_out"
            ]
        ]
    },
