        "z": "92e6400d7068ca5b",
        "name": "Symulacja Hala Produkcyjna",
        "func": "const hour = new Date().getHours();\nlet base = 0.5;\nif (hour >= 6 && hour < 14) base = 15.0;\nelse if (hour >= 14 && hour < 22) base = 12.0;\nelse base = 2.0;\nconst power = +(base + (Math.random() * 2.0 - 1.0)).toFixed(2);\nmsg.payload = JSON.stringify({ power: Math.max(0, power), location: 'hala' });\nmsg.topic = 'home/energy/hala';\nreturn msg;",
